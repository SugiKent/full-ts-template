// ========================================
// Prisma Schema
// Full-Stack TypeScript Template
// ========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 認証テーブル (Better Auth 標準)
// ========================================

// ユーザーアカウント (Better Auth の User テーブル)
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // カスタムフィールド: ロール（複数role対応）
  // 必要に応じてロール値を追加・変更してください
  // 例: 'admin' | 'user' | 'moderator'
  role String @default("user")

  // Better Auth 標準リレーション
  sessions Session[]
  accounts Account[]
}

// セッション (Better Auth 標準)
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// OAuth連携アカウント (Better Auth 標準)
model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String // Better Auth標準フィールド
  providerId   String // Better Auth標準フィールド
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String? // Email/パスワード認証用
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

// Verification (Better Auth 標準 - メール認証用)
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ========================================
// デバイス認証テーブル
// ========================================

// デバイス情報 - モバイルアプリの匿名認証用
model Device {
  id               String    @id @default(cuid())
  deviceId         String    @unique // クライアント生成 UUID
  platform         String? // ios, android
  appVersion       String?
  hasAgreedToTerms Boolean   @default(false)
  termsAgreedAt    DateTime?
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @updatedAt

  accessTokens   DeviceAccessToken[]
  userSettings   UserSettings?
  categories     Category[]
  wishlistItems  WishlistItem[]
  monthlyGoals   MonthlyGoal[]
  journalEntries JournalEntry[]

  @@index([deviceId])
}

// デバイスアクセストークン - 認証用トークン管理
model DeviceAccessToken {
  id        String    @id @default(cuid())
  deviceId  String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([token])
}

// ========================================
// アプリケーション固有のテーブル
// ========================================

// ユーザー設定
model UserSettings {
  id                    String    @id @default(cuid())
  deviceId              String    @unique
  notificationFrequency String    @default("daily") // daily, weekly, none
  themeId               String    @default("warm") // warm, cool, nature, minimal
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

// カテゴリー
model Category {
  id        String   @id @default(cuid())
  deviceId  String
  name      String
  icon      String?
  color     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  device Device                 @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  items  WishlistItemCategory[]

  @@index([deviceId])
}

// ウィッシュリストアイテム
model WishlistItem {
  id          String    @id @default(cuid())
  deviceId    String
  title       String
  description String?
  targetDate  DateTime?
  priority    Int       @default(0) // 0: low, 1: medium, 2: high
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  device          Device                 @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  categories      WishlistItemCategory[]
  steps           Step[]
  stepSuggestions StepSuggestion[]
  monthlyGoals    MonthlyGoal[]

  @@index([deviceId])
  @@index([deviceId, isCompleted])
}

// ウィッシュリストアイテムとカテゴリーの中間テーブル
model WishlistItemCategory {
  id         String   @id @default(cuid())
  itemId     String
  categoryId String
  createdAt  DateTime @default(now())

  item     WishlistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([itemId, categoryId])
  @@index([itemId])
  @@index([categoryId])
}

// ステップ（アイテムの達成に必要なタスク）
model Step {
  id          String    @id @default(cuid())
  itemId      String
  title       String
  description String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  item WishlistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([itemId, isCompleted])
}

// ステップ候補（AIが事前生成した未採用のステップ）
model StepSuggestion {
  id          String   @id @default(cuid())
  itemId      String
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  item WishlistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

// 月次目標
model MonthlyGoal {
  id          String    @id @default(cuid())
  deviceId    String
  itemId      String?
  title       String
  targetMonth DateTime // 対象月（YYYY-MM-01 形式）
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  device Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  item   WishlistItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([deviceId, targetMonth])
  @@index([itemId])
}

// ジャーナルエントリー（タイムライン機能）
model JournalEntry {
  id        String   @id @default(cuid())
  deviceId  String
  title     String? // 任意のタイトル
  content   String // 本文（最大5000文字）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([deviceId, createdAt])
}
